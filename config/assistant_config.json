{
    "llm": {
        "provider": "ollama",
        "model": "llama3.2:3b",
        "base_url": "http://localhost:11434",
        "max_history": 20
    },
    "stt": {
        "model_size": "base",
        "device": "auto"
    },
    "wake_word": {
        "keyword": "computer",
        "energy_threshold": 0.003,
        "hotkey": "ctrl+space"
    },
    "tts": {
        "rate": 175,
        "volume": 0.9
    },
    "recording": {
        "silence_timeout_sec": 1.5,
        "max_record_sec": 30.0,
        "sample_rate": 16000
    },
    "hud": {
        "enabled": false
    },
    "safe_mode": false,
    "logging": {
        "level": "INFO",
        "save_transcripts": false,
        "save_screenshots": true,
        "transcript_path": "logs/transcripts.log"
    }
}
