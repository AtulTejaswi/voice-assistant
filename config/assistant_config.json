{
    "llm": {
        "provider": "ollama",
        "model": "llama3.2:3b",
        "base_url": "http://localhost:11434",
        "max_history": 20,
        "system_prompt": "custom_prompts/jarvis.txt"
    },
    "stt": {
        "model_size": "base",
        "device": "auto"
    },
    "wake_word": {
        "keyword": "computer",
        "energy_threshold": 0.02,
        "hotkey": "ctrl+space"
    },
    "tts": {
        "rate": 175,
        "volume": 0.9
    },
    "recording": {
        "duration_seconds": 5,
        "sample_rate": 16000
    },
    "logging": {
        "level": "INFO",
        "save_transcripts": false,
        "transcript_path": "logs/transcripts.log"
    }
}
